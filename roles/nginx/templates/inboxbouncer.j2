# NGINX rate limit: https://www.nginx.com/blog/rate-limiting-nginx/
limit_req_zone $binary_remote_addr zone=sitelimit:10m rate=5r/s;

upstream {{ application_name }}_wsgi_server {
  # fail_timeout=0 means we always retry an upstream even if it failed
  # to return a good HTTP response (in case the Unicorn master nukes a
  # single worker for timing out).

  server unix:{{ virtualenv_path }}/run/gunicorn.sock fail_timeout=0;
}
#
# Redirect all non-encrypted to encrypted
#
server {
    server_name          {{ nginx_server_name }};
    listen               80;
    listen               [::]:80;

    return 301 https://$server_name$request_uri;
}
#
# Redirect all www to non-www
#
server {
    server_name www.{{ nginx_server_name }};
    listen      80;
    listen      443 ssl http2;
    listen      [::]:80 ipv6only=on;
    listen      [::]:443 ssl http2 ipv6only=on;
    {% if nginx_use_letsencrypt %}
    ssl_certificate     {{ letsencrypt_dir }}/{{ letsencrypt_cert_filename }};
    ssl_certificate_key {{ letsencrypt_dir }}/{{ letsencrypt_privkey_filename }};
    {% else %}
    ssl_certificate     {{ nginx_ssl_dest_dir }}/{{ application_name }}.crt;
    ssl_certificate_key {{ nginx_ssl_dest_dir }}/{{ application_name }}.key;
    {% endif %}
    ssl_protocols       TLSv1.2 TLSv1.3;

    return 301 https://{{ nginx_server_name }}$request_uri;
}

server {
    server_name         {{ nginx_server_name }};
    listen              443 ssl http2;
    listen              [::]:443 ssl http2;
    server_tokens       off;
    {% if nginx_use_letsencrypt %}
    ssl_certificate     {{ letsencrypt_dir }}/{{ letsencrypt_cert_filename }};
    ssl_certificate_key {{ letsencrypt_dir }}/{{ letsencrypt_privkey_filename }};
    {% else %}
    ssl_certificate     {{ nginx_ssl_dest_dir }}/{{ application_name }}.crt;
    ssl_certificate_key {{ nginx_ssl_dest_dir }}/{{ application_name }}.key;
    {% endif %}
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers on;
    {% if nginx_strong_dh_group %}
    ssl_dhparam          /etc/ssl/certs/dhparams.pem;
    {% endif %}

    # Various nginx optimizations via
    # https://www.digitalocean.com/community/tutorials/how-to-optimize-nginx-configuration
    # worker_processes 1;
    # worker_connections 1024;
    client_body_timeout 12;
    client_header_timeout 12;
    keepalive_timeout 15;
    send_timeout 10;
    client_body_buffer_size 10K;
    client_header_buffer_size 1k;
    client_max_body_size 4G;
    gzip             on;
    gzip_comp_level  2;
    gzip_min_length  1000;
    gzip_proxied     expired no-cache no-store private auth;
    gzip_types       text/plain text/javascript application/javascript application/x-javascript text/xml text/css application/xml;

    location /flower/ {
      #
      # Settings for flower monitoring
      #
      auth_basic "Restricted.";
      auth_basic_user_file /etc/nginx/passwdfile;
      charset              utf-8;
      proxy_pass http://127.0.0.1:5555;
      proxy_set_header Host $host;
      proxy_redirect off;
      proxy_http_version 1.1;
      proxy_set_header Upgrade $http_upgrade;
      proxy_set_header Connection "upgrade";
    }

    location /static/ {
        alias   {{ nginx_static_dir }};
        {% if nginx_cache_static %}
        expires {{ nginx_static_cache_expiry_period }};
        add_header Cache-Control "public";
        {% endif %}
    }

    location /files/ {
        alias   {{ nginx_files_dir }};
        {% if nginx_cache_files %}
        expires {{ nginx_files_cache_expiry_period }};
        add_header Cache-Control "public";
        {% endif %}
    }

    {% if nginx_include_favicon %}
    # alias favicon.* to static
    location ~ ^/favicon.(\w*)$ {
        alias {{ nginx_favicon_dir }}/favicon\.$1;
    }
    {% endif %}

    location / {
        if (-f {{ virtualenv_path }}/maintenance_on.html) {
            return 503;
        }

        limit_req zone=sitelimit burst=10 nodelay;

        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Host $http_host;
        proxy_redirect off;

        # Try to serve static files from nginx, no point in making an
        # *application* server like Unicorn/Rainbows! serve static files.
        if (!-f $request_filename) {
            proxy_pass http://{{ application_name }}_wsgi_server;
            break;
        }
    }

    # Error pages
    error_page 500 502 504 /500.html;
    location = /500.html {
        root {{ project_path }}/{{ application_name }}/templates/;
    }

    error_page 503 /maintenance_on.html;
    location = /maintenance_on.html {
        root {{ virtualenv_path }}/;
    }
}
